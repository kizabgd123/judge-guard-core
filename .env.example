# JudgeGuard + Auth0 Integration — Environment Variables
# Copy this file to .env and fill in your actual values.

# --- Gemini API ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- Auth0 Configuration ---
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=your_client_id
AUTH0_CLIENT_SECRET=your_client_secret
AUTH0_AUDIENCE=https://your-api-identifier

# --- JudgeGuard Paths (optional, auto-discovered if not set) ---
BRAIN_PATH=~/.gemini/antigravity/brain
WORK_LOG_PATH=./WORK_LOG.md

# --- Mock Mode (set to 'true' for hackathon demo without real Auth0 account) ---
MOCK_AUTH0=true
MOCK_GEMINI_JUDGE=true
